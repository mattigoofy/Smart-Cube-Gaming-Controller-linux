{
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Main",
            "type": "debugpy",
            "request": "launch",
            "program": "src/SmartCubeGamingController/main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "purpose": ["debug-test"],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}